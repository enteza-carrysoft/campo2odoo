# Odoo 18 Enterprise connection
ODOO_URL=https://miempresa.odoo.com
ODOO_DB=miempresa
ODOO_USERNAME=usuario@empresa.com
ODOO_API_KEY=

# Azure Document Intelligence
AZURE_DI_ENDPOINT=https://myresource.cognitiveservices.azure.com
